{
  "patchVersion": "major-category-weighted-seed-ranking-v1.0.0",
  "createdAt": "2026-07-24",
  "targetPath": "univ-search/public/keyword-engine/",
  "commitMessage": "Replace major filters with category-weighted seed ranking",
  "policy": {
    "candidatePool": "literal bestForSubjects match only; never filtered by major",
    "sortOrder": [
      "exact major match",
      "same engineering/natural/medical category",
      "other"
    ],
    "thinCategoryThreshold": 10,
    "fallbackCondition": "categoryMatchCount < 10",
    "medicalSplit": false
  },
  "validation": {
    "chemistryEngineering": {
      "subjectPool": 188,
      "categoryMatches": 175,
      "fallback": false
    },
    "chemistryNatural": {
      "subjectPool": 188,
      "categoryMatches": 181,
      "fallback": false
    },
    "chemistryMedical": {
      "subjectPool": 188,
      "categoryMatches": 115,
      "fallback": false
    },
    "biologyMedical": {
      "subjectPool": 180,
      "categoryMatches": 148,
      "fallback": false
    },
    "earthSystemMedical": {
      "subjectPool": 25,
      "categoryMatches": 3,
      "fallback": true,
      "effectivePool": 25
    },
    "geometryMedical": {
      "subjectPool": 34,
      "categoryMatches": 10,
      "fallback": false
    }
  },
