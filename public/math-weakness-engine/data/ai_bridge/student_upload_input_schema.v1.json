{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koreapoorboy-coder.github.io/univ-search/math-weakness-engine/data/ai_bridge/student_upload_input_schema.v1.json",
  "title": "Math Weakness Hybrid Student Upload Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "student_profile",
    "learning_context",
    "submission",
    "analysis_options"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "student_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "student_name",
        "grade_label"
      ],
      "properties": {
        "student_name": {
          "type": "string"
        },
        "grade_label": {
          "type": "string",
          "description": "예: 중1, 중2, 고1, 고2"
        },
        "school_name": {
          "type": "string"
        },
        "class_group": {
          "type": "string"
        },
        "teacher_memo": {
          "type": "string"
        }
      }
    },
    "learning_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "course",
        "unit_name"
      ],
      "properties": {
        "course": {
          "type": "string"
        },
        "unit_id": {
          "type": "string"
        },
        "unit_name": {
          "type": "string"
        },
        "lesson_title": {
          "type": "string"
        },
        "exam_title": {
          "type": "string"
        },
        "wrong_question_numbers": {
          "type": "array",
          "items": {
            "type": [
              "integer",
              "string"
            ]
          }
        },
        "known_problem_type_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "teacher_focus": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "submission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text_inputs",
        "file_manifest"
      ],
      "properties": {
        "text_inputs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "student_solution_text": {
              "type": "string"
            },
            "lecture_note_text": {
              "type": "string"
            },
            "verification_answer_text": {
              "type": "string"
            },
            "student_self_reflection": {
              "type": "string"
            }
          }
        },
        "file_manifest": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "file_role",
              "filename"
            ],
            "properties": {
              "file_role": {
                "type": "string",
                "enum": [
                  "exam_pdf",
                  "marked_exam_pdf",
                  "solution_image",
                  "lecture_note_image",
                  "verification_answer_image",
                  "other"
                ]
              },
              "filename": {
                "type": "string"
              },
              "mime_type": {
                "type": "string"
              },
              "page_or_question_hint": {
                "type": "string"
              },
              "student_note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "analysis_options": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "output_targets"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "low_cost",
            "balanced",
            "high_precision"
          ]
        },
        "output_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "student",
              "parent",
              "teacher"
            ]
          }
        },
        "generate_verification_questions": {
          "type": "boolean"
        },
        "review_verification_answer": {
          "type": "boolean"
        },
        "use_existing_math_engine": {
          "type": "boolean"
        }
      }
    }
  }
}