{
  "meta": {
    "name": "level_judgment_rules",
    "version": "0.1.0-starter",
    "description": "일반 학생부와 합격생 데이터를 함께 비교해 현재 위치와 수준을 판정하는 규칙"
  },
  "rules": [
    {
      "id": "rule_general_upper",
      "when": {
        "record_pattern_type_any": [
          "강한 일관성",
          "데이터 기반형"
        ],
        "strength_count_gte": 2
      },
      "set": {
        "general_position": "상위권"
      },
      "notes": "일반 학생부 기준으로 방향성과 수행 흔적이 분명한 경우"
    },
    {
      "id": "rule_general_mid_upper",
      "when": {
        "record_pattern_type_any": [
          "확장 가능",
          "표현 강점형"
        ]
      },
      "set": {
        "general_position": "중상위권"
      },
      "notes": "방향성은 있으나 심화나 완성도가 더 필요한 경우"
    },
    {
      "id": "rule_general_risk",
      "when": {
        "record_pattern_type_any": [
          "과다 분산형"
        ]
      },
      "set": {
        "general_position": "보완 필요"
      },
      "notes": "활동은 있으나 축이 분산된 경우"
    },
    {
      "id": "rule_admission_near",
      "when": {
        "admission_match_count_gte": 2,
        "extension_match_count_gte": 2,
        "weakness_count_lte": 1
      },
      "set": {
        "admission_position": "합격권 근접"
      },
      "notes": "합격생 패턴과 유사성이 높고 일반 패턴 약점이 적은 경우"
    },
    {
      "id": "rule_admission_pre_near",
      "when": {
        "admission_match_count_gte": 1,
        "extension_match_count_gte": 1
      },
      "set": {
        "admission_position": "도달 직전"
      },
      "notes": "방향성은 맞지만 탐구 완성도나 결과 정리가 더 필요한 경우"
    },
    {
      "id": "rule_admission_gap",
      "when": {
        "admission_match_count_eq": 0
      },
      "set": {
        "admission_position": "기초 보정 단계"
      },
      "notes": "합격생 패턴과 직접 연결되는 증거가 아직 약한 경우"
    }
  ]
}
