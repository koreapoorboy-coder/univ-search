        "전파정보통신공학"
      ],
      "prefer_subjects_any": [
        "물리학",
        "화학",
        "대수",
        "미적분",
        "정보"
      ],
      "notes": "공학계열 합격생 비교 시 이수과목 적합도 우선 확인"
    },
    {
      "id": "rule_bio_medical_fit",
