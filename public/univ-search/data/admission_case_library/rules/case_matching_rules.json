      ],
      "prefer_activity_any": [
        "교과연계",
        "전공심화",
        "융합탐구",
        "논증글쓰기"
      ],
      "notes": "상위권 대학 비교 시 활동 수보다 연결성·심화도·일관성 우선"
    }
